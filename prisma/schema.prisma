generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(SELLER)
  createdAt DateTime @default(now())

  sales    Sale[]
  expenses Expense[]
  goals    Goal[]
}

enum Role {
  ADMIN
  SELLER
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id             Int      @id @default(autoincrement())
  name           String
  description    String?
  brand          String?
  categoryId     Int
  category       Category @relation(fields: [categoryId], references: [id])
  costPrice      Float
  retailPrice    Float
  wholesalePrice Float
  stock          Int      @default(0)
  minStock       Int      @default(5)
  unit           String   @default("unidad")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  inventoryMovements InventoryMovement[]
  saleItems          SaleItem[]
}

model InventoryMovement {
  id        Int          @id @default(autoincrement())
  productId Int
  product   Product      @relation(fields: [productId], references: [id])
  type      MovementType
  quantity  Int
  reason    String?
  notes     String?
  date      DateTime     @default(now())
  createdBy Int?
}

enum MovementType {
  ENTRADA
  SALIDA
}

model Zone {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  customers Customer[]
}

model Customer {
  id             Int          @id @default(autoincrement())
  name           String
  phone          String?
  address        String?
  zoneId         Int?
  zone           Zone?        @relation(fields: [zoneId], references: [id])
  type           CustomerType @default(DETAL)
  birthday       DateTime?
  lastPurchaseAt DateTime?
  totalLifetime  Float        @default(0)
  visitCount     Int          @default(0)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  sales             Sale[]
  scheduledMessages ScheduledMessage[]
}

enum CustomerType {
  DETAL
  MAYOR
}

model Sale {
  id         Int           @id @default(autoincrement())
  customerId Int
  customer   Customer      @relation(fields: [customerId], references: [id])
  type       SaleType      @default(DETAL)
  method     PaymentMethod @default(EFECTIVO)
  total      Float
  profit     Float
  notes      String?
  date       DateTime      @default(now())
  sellerId   Int?
  seller     User?         @relation(fields: [sellerId], references: [id])

  items      SaleItem[]
  creditSale CreditSale?
}

enum SaleType {
  DETAL
  MAYOR
}

enum PaymentMethod {
  EFECTIVO
  ADDI
  SISTECREDITO
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  costPrice Float
  subtotal  Float
}

model CreditSale {
  id        Int            @id @default(autoincrement())
  saleId    Int            @unique
  sale      Sale           @relation(fields: [saleId], references: [id])
  platform  CreditPlatform
  reference String?
  status    String         @default("PENDIENTE")
  amount    Float
  createdAt DateTime       @default(now())
}

enum CreditPlatform {
  ADDI
  SISTECREDITO
}

model Expense {
  id       Int      @id @default(autoincrement())
  category String   @default("General")
  label    String
  amount   Float
  date     DateTime @default(now())
  sellerId Int?
  seller   User?    @relation(fields: [sellerId], references: [id])
}

model Goal {
  id           Int      @id @default(autoincrement())
  type         GoalType
  targetAmount Float
  startDate    DateTime
  endDate      DateTime
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
}

enum GoalType {
  WEEKLY
  MONTHLY
  MAYORISTA
}

model MessageTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  body      String
  type      String   @default("general")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  scheduledMessages ScheduledMessage[]
}

model ScheduledMessage {
  id         Int             @id @default(autoincrement())
  customerId Int
  customer   Customer        @relation(fields: [customerId], references: [id])
  templateId Int
  template   MessageTemplate @relation(fields: [templateId], references: [id])
  body       String
  sendAt     DateTime
  sent       Boolean         @default(false)
  createdAt  DateTime        @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
